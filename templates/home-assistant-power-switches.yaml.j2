# Generated by playbooks/generate_home_assistant_power_switches.yml
# Include this file from Home Assistant as a package,
# or merge the top-level command_line key into your existing configuration.
{% set linux_groups = home_assistant_linux_power_groups %}
{% set macos_groups = home_assistant_macos_power_groups %}
{% set base_url = home_assistant_webhook_base_url.rstrip('/') %}
{% set ping_count = home_assistant_ping_count %}
{% set ping_timeout = home_assistant_ping_timeout_seconds %}
command_line:
{% for host_name in home_assistant_power_hosts | sort %}
{% set group_names = hostvars[host_name].group_names %}
{% if (group_names | intersect(linux_groups) | length) > 0 %}
{% set power_off_endpoint = '/webhook/suspend/linux' %}
{% else %}
{% set power_off_endpoint = '/webhook/sleep/macos' %}
{% endif %}
{% set slug = host_name | lower | regex_replace('[^a-z0-9_]+', '_') %}
  - switch:
      name: "{{ host_name }} Power"
      unique_id: "ansible_power_{{ slug }}"
      icon: mdi:power
      command_on: >-
        curl --silent --show-error --fail
        -X POST
        -H {{ ('X-Webhook-Token: ' ~ home_assistant_webhook_token) | quote }}
        -H 'Content-Type: application/json'
        --data {{ ({'limit': host_name, 'connection_path': 'local'} | to_json) | quote }}
        {{ (base_url ~ '/webhook/wake') | quote }}
      command_off: >-
        curl --silent --show-error --fail
        -X POST
        -H {{ ('X-Webhook-Token: ' ~ home_assistant_webhook_token) | quote }}
        -H 'Content-Type: application/json'
        --data {{ ({'limit': host_name, 'connection_path': 'local'} | to_json) | quote }}
        {{ (base_url ~ power_off_endpoint) | quote }}
      command_state: >-
        ping -c {{ ping_count }} -W {{ ping_timeout }}
        {{ hostvars[host_name].local_ip | quote }} >/dev/null 2>&1 && echo ON || echo OFF
      value_template: "{% raw %}{{ value == 'ON' }}{% endraw %}"
{% endfor %}
