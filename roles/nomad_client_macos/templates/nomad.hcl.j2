data_dir = "{{ nomad_data_dir }}"
bind_addr = "{{ nomad_bind_addr }}"

region = "{{ nomad_region }}"
datacenter = "{{ nomad_datacenter }}"
log_level = "{{ nomad_log_level }}"

advertise {
  http = "{{ nomad_advertise_http }}"
}

client {
  enabled = {{ nomad_client_enabled | bool | lower }}
  servers = [
{% for server in nomad_client_servers %}
    "{{ server }}"{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% if nomad_client_network_interface | length > 0 %}
  network_interface = "{{ nomad_client_network_interface }}"
{% endif %}
{% if nomad_client_node_class | length > 0 %}
  node_class = "{{ nomad_client_node_class }}"
{% endif %}
{% if nomad_client_meta | length > 0 %}

  meta {
{% for key, value in nomad_client_meta | dictsort %}
    "{{ key }}" = "{{ value }}"
{% endfor %}
  }
{% endif %}
{% if nomad_client_host_volumes | length > 0 %}
{% for volume in nomad_client_host_volumes %}

  host_volume "{{ volume.name }}" {
    path = "{{ volume.path }}"
    read_only = {{ volume.read_only | default(false) | bool | lower }}
  }
{% endfor %}
{% endif %}
}

plugin "raw_exec" {
  config {
    enabled = {{ nomad_raw_exec_enabled | bool | lower }}
  }
}
